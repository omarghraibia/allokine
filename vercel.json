{
  "framework": "vite",
  "installCommand": "npm install && npm --prefix backend install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...route].js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
