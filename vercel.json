{
  "framework": "vite",
  "installCommand": "npm ci && npm ci --prefix backend",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...route].js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
